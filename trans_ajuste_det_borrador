    [referencia_ajuste_erp] NVARCHAR(50) NOT NULL CONSTRAINT [DF_trans_ajuste_det_borrador_referencia_ajuste_erp] DEFAULT (''),
    [estado_ajuste_erp] BIT NOT NULL CONSTRAINT [DF_trans_ajuste_det_borrador_estado_ajuste_erp] DEFAULT ((0)),
