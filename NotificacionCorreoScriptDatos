        ReporteCodigo           VARCHAR(100) NULL,
        Activo                  BIT NOT NULL CONSTRAINT DF_NotificacionAdjunto_Activo DEFAULT (1),
        FechaCreacion           DATETIME2(0) NOT NULL CONSTRAINT DF_NotificacionAdjunto_FechaCreacion DEFAULT (SYSDATETIME()),
        CONSTRAINT FK_NotificacionAdjunto_Cola
            FOREIGN KEY (IdColaNotificacion) REFERENCES dbo.NotificacionCola(IdColaNotificacion)
