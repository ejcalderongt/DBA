BEGIN TRY
    BEGIN TRANSACTION;

    /* =========================================================
       1. TABLAS
       ========================================================= */

    IF OBJECT_ID('dbo.NotificacionAdjunto', 'U') IS NOT NULL
        DROP TABLE dbo.NotificacionAdjunto;

    IF OBJECT_ID('dbo.NotificacionLog', 'U') IS NOT NULL
        DROP TABLE dbo.NotificacionLog;

    IF OBJECT_ID('dbo.NotificacionCola', 'U') IS NOT NULL
        DROP TABLE dbo.NotificacionCola;

    IF OBJECT_ID('dbo.BodegaNotificacionContacto', 'U') IS NOT NULL
        DROP TABLE dbo.BodegaNotificacionContacto;

    IF OBJECT_ID('dbo.NotificacionDestinatarioRegla', 'U') IS NOT NULL
        DROP TABLE dbo.NotificacionDestinatarioRegla;

    IF OBJECT_ID('dbo.NotificacionEventoVariable', 'U') IS NOT NULL
        DROP TABLE dbo.NotificacionEventoVariable;

    IF OBJECT_ID('dbo.NotificacionPlantilla', 'U') IS NOT NULL
        DROP TABLE dbo.NotificacionPlantilla;

    IF OBJECT_ID('dbo.NotificacionLayout', 'U') IS NOT NULL
        DROP TABLE dbo.NotificacionLayout;

    IF OBJECT_ID('dbo.NotificacionEvento', 'U') IS NOT NULL
        DROP TABLE dbo.NotificacionEvento;

    IF OBJECT_ID('dbo.vw_NotificacionPlantilla', 'V') IS NOT NULL
        DROP VIEW dbo.vw_NotificacionPlantilla;

    /* =========================================================
       2. CATALOGO DE EVENTOS
       ========================================================= */

    CREATE TABLE dbo.NotificacionEvento
    (
        IdEvento                INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        CodigoEvento            VARCHAR(100) NOT NULL,
        NombreEvento            VARCHAR(150) NOT NULL,
        Modulo                  VARCHAR(100) NULL,
        Descripcion             VARCHAR(500) NULL,
        Activo                  BIT NOT NULL CONSTRAINT DF_NotificacionEvento_Activo DEFAULT (1),
        FechaCreacion           DATETIME2(0) NOT NULL CONSTRAINT DF_NotificacionEvento_FechaCreacion DEFAULT (SYSDATETIME()),
        UsuarioCreacion         VARCHAR(100) NULL,
        FechaModificacion       DATETIME2(0) NULL,
        UsuarioModificacion     VARCHAR(100) NULL
    );

    CREATE UNIQUE INDEX UX_NotificacionEvento_CodigoEvento
    ON dbo.NotificacionEvento (CodigoEvento);

    /* =========================================================
       3. LAYOUT DE CORREO
       ========================================================= */

    CREATE TABLE dbo.NotificacionLayout
    (
        IdLayout                INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        CodigoLayout            VARCHAR(50) NOT NULL,
        NombreLayout            VARCHAR(150) NOT NULL,
        HeaderHtml              NVARCHAR(MAX) NULL,
        FooterHtml              NVARCHAR(MAX) NULL,
        CssInline               NVARCHAR(MAX) NULL,
        Activo                  BIT NOT NULL CONSTRAINT DF_NotificacionLayout_Activo DEFAULT (1),
        EsDefault               BIT NOT NULL CONSTRAINT DF_NotificacionLayout_EsDefault DEFAULT (0),
        FechaCreacion           DATETIME2(0) NOT NULL CONSTRAINT DF_NotificacionLayout_FechaCreacion DEFAULT (SYSDATETIME()),
        UsuarioCreacion         VARCHAR(100) NULL,
        FechaModificacion       DATETIME2(0) NULL,
        UsuarioModificacion     VARCHAR(100) NULL
    );

    CREATE UNIQUE INDEX UX_NotificacionLayout_CodigoLayout
    ON dbo.NotificacionLayout (CodigoLayout);

    /* =========================================================
       4. PLANTILLAS
       ========================================================= */

    CREATE TABLE dbo.NotificacionPlantilla
    (
        IdPlantilla             INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        IdEvento                INT NOT NULL,
        IdLayout                INT NULL,
        CodigoPlantilla         VARCHAR(100) NOT NULL,
        NombrePlantilla         VARCHAR(150) NOT NULL,
        Canal                   VARCHAR(20) NOT NULL CONSTRAINT DF_NotificacionPlantilla_Canal DEFAULT ('EMAIL'),
        AsuntoTemplate          NVARCHAR(500) NOT NULL,
        BodyHtmlTemplate        NVARCHAR(MAX) NOT NULL,
        UsaLayoutComun          BIT NOT NULL CONSTRAINT DF_NotificacionPlantilla_UsaLayoutComun DEFAULT (1),
        VersionPlantilla        INT NOT NULL CONSTRAINT DF_NotificacionPlantilla_Version DEFAULT (1),
        Activo                  BIT NOT NULL CONSTRAINT DF_NotificacionPlantilla_Activo DEFAULT (1),
        FechaCreacion           DATETIME2(0) NOT NULL CONSTRAINT DF_NotificacionPlantilla_FechaCreacion DEFAULT (SYSDATETIME()),
        UsuarioCreacion         VARCHAR(100) NULL,
        FechaModificacion       DATETIME2(0) NULL,
        UsuarioModificacion     VARCHAR(100) NULL,
        CONSTRAINT FK_NotificacionPlantilla_Evento
            FOREIGN KEY (IdEvento) REFERENCES dbo.NotificacionEvento(IdEvento),
        CONSTRAINT FK_NotificacionPlantilla_Layout
            FOREIGN KEY (IdLayout) REFERENCES dbo.NotificacionLayout(IdLayout),
        CONSTRAINT CK_NotificacionPlantilla_Canal
            CHECK (Canal IN ('EMAIL'))
    );

    CREATE UNIQUE INDEX UX_NotificacionPlantilla_CodigoPlantilla
    ON dbo.NotificacionPlantilla (CodigoPlantilla);

    CREATE INDEX IX_NotificacionPlantilla_IdEvento
    ON dbo.NotificacionPlantilla (IdEvento, Activo);

    /* =========================================================
       5. VARIABLES DEL EVENTO
       ========================================================= */

    CREATE TABLE dbo.NotificacionEventoVariable
    (
        IdEventoVariable        INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        IdEvento                INT NOT NULL,
        NombreVariable          VARCHAR(100) NOT NULL,
        Descripcion             VARCHAR(300) NULL,
        EjemploValor            VARCHAR(300) NULL,
        Obligatoria             BIT NOT NULL CONSTRAINT DF_NotificacionEventoVariable_Obligatoria DEFAULT (0),
        Activo                  BIT NOT NULL CONSTRAINT DF_NotificacionEventoVariable_Activo DEFAULT (1),
        CONSTRAINT FK_NotificacionEventoVariable_Evento
            FOREIGN KEY (IdEvento) REFERENCES dbo.NotificacionEvento(IdEvento)
    );

    CREATE UNIQUE INDEX UX_NotificacionEventoVariable_EventoVariable
    ON dbo.NotificacionEventoVariable (IdEvento, NombreVariable);

    /* =========================================================
       6. REGLAS DE DESTINATARIOS
       ========================================================= */

    CREATE TABLE dbo.NotificacionDestinatarioRegla
    (
        IdReglaDestinatario         INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        IdEvento                    INT NOT NULL,

        TipoDestinatario            VARCHAR(10) NOT NULL,
        OrigenDestinatario          VARCHAR(30) NOT NULL,
        ValorOrigen                 NVARCHAR(500) NOT NULL,

        EmpresaCodigo               VARCHAR(20) NULL,
        SucursalCodigo              VARCHAR(20) NULL,
        TipoDocumento               VARCHAR(20) NULL,

        ContextoBodega              VARCHAR(20) NULL,
        CodigoBodegaFiltro          VARCHAR(20) NULL,

        Prioridad                   INT NOT NULL
            CONSTRAINT DF_NotificacionDestinatarioRegla_Prioridad DEFAULT (1),

        RequiereCoincidenciaExacta  BIT NOT NULL
            CONSTRAINT DF_NotificacionDestinatarioRegla_Exacta DEFAULT (0),

        Activo                      BIT NOT NULL
            CONSTRAINT DF_NotificacionDestinatarioRegla_Activo DEFAULT (1),

        Observaciones               VARCHAR(300) NULL,

        FechaCreacion               DATETIME2(0) NOT NULL
            CONSTRAINT DF_NotificacionDestinatarioRegla_FechaCreacion DEFAULT (SYSDATETIME()),

        UsuarioCreacion             VARCHAR(100) NULL,
        FechaModificacion           DATETIME2(0) NULL,
        UsuarioModificacion         VARCHAR(100) NULL,

        CONSTRAINT FK_NotificacionDestinatarioRegla_Evento
            FOREIGN KEY (IdEvento)
            REFERENCES dbo.NotificacionEvento (IdEvento),

        CONSTRAINT CK_NotificacionDestinatarioRegla_TipoDestinatario
            CHECK (TipoDestinatario IN ('TO', 'CC', 'BCC')),

        CONSTRAINT CK_NotificacionDestinatarioRegla_OrigenDestinatario
            CHECK (OrigenDestinatario IN ('FIJO', 'CLIENTE', 'BODEGA', 'USUARIO', 'ROL', 'QUERY')),

        CONSTRAINT CK_NotificacionDestinatarioRegla_ContextoBodega
            CHECK (ContextoBodega IN ('ORIGEN', 'DESTINO', 'AMBAS') OR ContextoBodega IS NULL),

        CONSTRAINT CK_NotificacionDestinatarioRegla_ContextoBodega_BODEGA
            CHECK (
                (OrigenDestinatario = 'BODEGA' AND ContextoBodega IS NOT NULL)
                OR
                (OrigenDestinatario <> 'BODEGA')
            )
    );

    CREATE INDEX IX_NotificacionDestinatarioRegla_Evento
    ON dbo.NotificacionDestinatarioRegla (IdEvento, Activo, Prioridad);

    CREATE INDEX IX_NotificacionDestinatarioRegla_Busqueda
    ON dbo.NotificacionDestinatarioRegla
    (
        IdEvento,
        EmpresaCodigo,
        SucursalCodigo,
        TipoDocumento,
        ContextoBodega,
        CodigoBodegaFiltro,
        Activo
    );

    /* =========================================================
       7. CONTACTOS POR BODEGA
       ========================================================= */

    CREATE TABLE dbo.BodegaNotificacionContacto
    (
        IdBodegaContacto            INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        EmpresaCodigo               VARCHAR(20) NOT NULL,
        SucursalCodigo              VARCHAR(20) NULL,
        BodegaCodigo                VARCHAR(20) NOT NULL,

        TipoContacto                VARCHAR(30) NOT NULL,
        NombreContacto              VARCHAR(150) NULL,
        Correo                      VARCHAR(320) NOT NULL,

        PermiteTo                   BIT NOT NULL
            CONSTRAINT DF_BodegaNotificacionContacto_PermiteTo DEFAULT (1),

        PermiteCc                   BIT NOT NULL
            CONSTRAINT DF_BodegaNotificacionContacto_PermiteCc DEFAULT (1),

        PermiteBcc                  BIT NOT NULL
            CONSTRAINT DF_BodegaNotificacionContacto_PermiteBcc DEFAULT (0),

        EsPrincipal                 BIT NOT NULL
            CONSTRAINT DF_BodegaNotificacionContacto_EsPrincipal DEFAULT (0),

        Activo                      BIT NOT NULL
            CONSTRAINT DF_BodegaNotificacionContacto_Activo DEFAULT (1),

        Observaciones               VARCHAR(300) NULL,

        FechaCreacion               DATETIME2(0) NOT NULL
            CONSTRAINT DF_BodegaNotificacionContacto_FechaCreacion DEFAULT (SYSDATETIME()),

        UsuarioCreacion             VARCHAR(100) NULL,
        FechaModificacion           DATETIME2(0) NULL,
        UsuarioModificacion         VARCHAR(100) NULL,

        CONSTRAINT CK_BodegaNotificacionContacto_TipoContacto
            CHECK (TipoContacto IN ('OPERATIVO', 'SUPERVISOR', 'JEFE', 'AUDITORIA', 'DESPACHO', 'RECEPCION'))
    );

    CREATE UNIQUE INDEX UX_BodegaNotificacionContacto_Unico
    ON dbo.BodegaNotificacionContacto
    (
        EmpresaCodigo,
        SucursalCodigo,
        BodegaCodigo,
        TipoContacto,
        Correo
    );

    CREATE INDEX IX_BodegaNotificacionContacto_Busqueda
    ON dbo.BodegaNotificacionContacto
    (
        EmpresaCodigo,
        SucursalCodigo,
        BodegaCodigo,
        TipoContacto,
        Activo
    );

    /* =========================================================
       8. COLA DE NOTIFICACIONES
       ========================================================= */

    CREATE TABLE dbo.NotificacionCola
    (
        IdColaNotificacion      BIGINT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        IdEvento                INT NOT NULL,
        IdPlantilla             INT NULL,
        OrigenSistema           VARCHAR(50) NOT NULL CONSTRAINT DF_NotificacionCola_OrigenSistema DEFAULT ('TOMWMS'),
        LlaveNegocio            VARCHAR(200) NULL,
        EmpresaCodigo           VARCHAR(20) NULL,
        SucursalCodigo          VARCHAR(20) NULL,
        BodegaCodigo            VARCHAR(20) NULL,
        TipoDocumento           VARCHAR(20) NULL,
        Referencia1             VARCHAR(100) NULL,
        Referencia2             VARCHAR(100) NULL,
        DataJson                NVARCHAR(MAX) NOT NULL,
        Estado                  VARCHAR(20) NOT NULL CONSTRAINT DF_NotificacionCola_Estado DEFAULT ('PENDIENTE'),
        Intentos                INT NOT NULL CONSTRAINT DF_NotificacionCola_Intentos DEFAULT (0),
        MaxIntentos             INT NOT NULL CONSTRAINT DF_NotificacionCola_MaxIntentos DEFAULT (5),
        FechaProgramada         DATETIME2(0) NOT NULL CONSTRAINT DF_NotificacionCola_FechaProgramada DEFAULT (SYSDATETIME()),
        FechaUltimoIntento      DATETIME2(0) NULL,
        FechaProcesado          DATETIME2(0) NULL,
        ErrorUltimo             NVARCHAR(2000) NULL,
        UsuarioCreacion         VARCHAR(100) NULL,
        FechaCreacion           DATETIME2(0) NOT NULL CONSTRAINT DF_NotificacionCola_FechaCreacion DEFAULT (SYSDATETIME()),
        CONSTRAINT FK_NotificacionCola_Evento
            FOREIGN KEY (IdEvento) REFERENCES dbo.NotificacionEvento(IdEvento),
        CONSTRAINT FK_NotificacionCola_Plantilla
            FOREIGN KEY (IdPlantilla) REFERENCES dbo.NotificacionPlantilla(IdPlantilla),
        CONSTRAINT CK_NotificacionCola_Estado
            CHECK (Estado IN ('PENDIENTE', 'PROCESANDO', 'ENVIADO', 'ERROR', 'CANCELADO'))
    );

    CREATE INDEX IX_NotificacionCola_Estado_FechaProgramada
    ON dbo.NotificacionCola (Estado, FechaProgramada);

    CREATE INDEX IX_NotificacionCola_LlaveNegocio
    ON dbo.NotificacionCola (LlaveNegocio);

    /* =========================================================
       9. LOG DE NOTIFICACIONES
       ========================================================= */

    CREATE TABLE dbo.NotificacionLog
    (
        IdLogNotificacion       BIGINT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        IdColaNotificacion      BIGINT NULL,
        IdEvento                INT NOT NULL,
        IdPlantilla             INT NULL,
        EstadoEnvio             VARCHAR(20) NOT NULL,
        AsuntoGenerado          NVARCHAR(500) NULL,
        BodyGenerado            NVARCHAR(MAX) NULL,
        DestinatariosTo         NVARCHAR(MAX) NULL,
        DestinatariosCc         NVARCHAR(MAX) NULL,
        DestinatariosBcc        NVARCHAR(MAX) NULL,
        Remitente               VARCHAR(320) NULL,
        ProveedorEnvio          VARCHAR(50) NULL,
        MessageIdExterno        VARCHAR(500) NULL,
        ErrorTecnico            NVARCHAR(3000) NULL,
        DataJson                NVARCHAR(MAX) NULL,
        FechaEnvio              DATETIME2(0) NOT NULL CONSTRAINT DF_NotificacionLog_FechaEnvio DEFAULT (SYSDATETIME()),
        UsuarioProceso          VARCHAR(100) NULL,
        CONSTRAINT FK_NotificacionLog_Cola
            FOREIGN KEY (IdColaNotificacion) REFERENCES dbo.NotificacionCola(IdColaNotificacion),
        CONSTRAINT FK_NotificacionLog_Evento
            FOREIGN KEY (IdEvento) REFERENCES dbo.NotificacionEvento(IdEvento),
        CONSTRAINT FK_NotificacionLog_Plantilla
            FOREIGN KEY (IdPlantilla) REFERENCES dbo.NotificacionPlantilla(IdPlantilla),
        CONSTRAINT CK_NotificacionLog_EstadoEnvio
            CHECK (EstadoEnvio IN ('ENVIADO', 'ERROR', 'OMITIDO'))
    );

    CREATE INDEX IX_NotificacionLog_IdCola
    ON dbo.NotificacionLog (IdColaNotificacion);

    CREATE INDEX IX_NotificacionLog_FechaEnvio
    ON dbo.NotificacionLog (FechaEnvio DESC);

    /* =========================================================
       10. ADJUNTOS
       ========================================================= */

    CREATE TABLE dbo.NotificacionAdjunto
    (
        IdAdjunto               BIGINT IDENTITY(1,1) NOT NULL PRIMARY KEY,
